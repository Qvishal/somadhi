Options -Indexes

# ── Gzip Compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ── Browser Caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # HTML — short cache (1 hour)
    ExpiresByType text/html                 "access plus 1 hour"
    # CSS & JS — 1 year (cache-busted by filename changes)
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    # Images & fonts — 1 year
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Cache-Control for static assets
    <FilesMatch "\.(css|js|png|jpg|jpeg|svg|webp|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Clean URLs ────────────────────────────────────────────────────────────────
RewriteEngine On

# If the request is for an actual file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Map /products  -> /products.php
# Map /catalogues -> /catalogues.php
# Map /contact   -> /contact.php
RewriteRule ^products$   products.php   [L]
RewriteRule ^catalogues$ catalogues.php [L]
RewriteRule ^contact$    contact.php    [L]

# Redirect old .php URLs to clean URLs (301 permanent)
RewriteCond %{THE_REQUEST} /index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

RewriteCond %{THE_REQUEST} /products\.php[\s?] [NC]
RewriteRule ^products\.php$ /products [R=301,L]

RewriteCond %{THE_REQUEST} /catalogues\.php[\s?] [NC]
RewriteRule ^catalogues\.php$ /catalogues [R=301,L]

RewriteCond %{THE_REQUEST} /contact\.php[\s?] [NC]
RewriteRule ^contact\.php$ /contact [R=301,L]
